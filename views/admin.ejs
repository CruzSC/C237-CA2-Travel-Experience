<%# Member 5 - Cruz: Admin management view %>
<%- include('partials/header') %>

<div class="text-center">
    <h2>Admin Page</h2>
    <p><%= users.length %> users and <%= experiences.length %> experiences</p>
</div>

<section class="admin-section">
    <h2>Users</h2>
    <div class="table-responsive">
        <table class="table table-hover text-center align-middle">
            <thead>
                <tr><th>Name</th><th>Email</th><th>Role</th><th>Joined</th><th>Action</th></tr>
            </thead>
            <tbody>
                <% users.forEach((account) => { %>
                    <tr>
                        <td><%= account.username %></td>
                        <td><%= account.email %></td>
                        <td><%= account.role %></td>
                        <td><%= new Date(account.createdAt).toLocaleDateString('en-SG') %></td>
                        <td>
                            <div class="d-flex justify-content-center align-items-center gap-2">
                                <form class="inline-form" action="/admin/users/<%= account.userId %>/role" method="POST">
                                    <select class="form-select form-select-sm" name="role" aria-label="Role for <%= account.username %>">
                                        <option value="user" <%= account.role === 'user' ? 'selected' : '' %>>User</option>
                                        <option value="admin" <%= account.role === 'admin' ? 'selected' : '' %>>Admin</option>
                                    </select>
                                    <button class="btn btn-primary btn-sm" type="submit">Update</button>
                                </form>
                                <% if (user.userId !== account.userId) { %>
                                    <form action="/admin/users/<%= account.userId %>/delete" method="POST" onsubmit="return confirm('Delete this user and all of their experiences?');">
                                        <button class="btn btn-danger btn-sm" type="submit">Delete</button>
                                    </form>
                                <% } else { %>
                                    <span class="text-muted small">Current account</span>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</section>

<section class="admin-section">
    <h2>All experiences</h2>
    <div class="table-responsive">
        <table class="table table-hover text-center align-middle">
            <thead>
                <tr><th>Title</th><th>Destination</th><th>Owner</th><th>Date</th><th>Status</th><th>Action</th></tr>
            </thead>
            <tbody>
                <% experiences.forEach((experience) => { %>
                    <tr>
                        <td><a href="/experiences/<%= experience.experienceId %>"><%= experience.title %></a></td>
                        <td><%= experience.destination %>, <%= experience.country %></td>
                        <td><%= experience.username %></td>
                        <td><%= new Date(experience.experienceDate).toLocaleDateString('en-SG') %></td>
                        <td>
                            <%= experience.status %>
                        </td>
                        <td>
                            <form class="inline-form" action="/admin/experiences/<%= experience.experienceId %>/status" method="POST">
                                <select class="form-select form-select-sm" name="status">
                                    <option value="planned" <%= experience.status === 'planned' ? 'selected' : '' %>>Planned</option>
                                    <option value="completed" <%= experience.status === 'completed' ? 'selected' : '' %>>Completed</option>
                                    <option value="cancelled" <%= experience.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                                </select>
                                <button class="btn btn-primary btn-sm" type="submit">Update</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</section>

<%- include('partials/footer') %>
