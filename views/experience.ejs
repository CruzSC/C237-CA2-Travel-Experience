<%# Member 3 - Mithulen: View one experience %>
<%- include('./partials/header') %>

<div class="container mt-4">
    <div class="card mb-3">
        <% if (experience.image) { %>
            <img src="/images/<%= experience.image %>" class="card-img-top" alt="<%= experience.title %>" style="max-height: 400px; object-fit: cover;">
        <% } %>
        <div class="card-body">
            <h1 class="card-title"><%= experience.title %></h1>
            <h4 class="text-muted"><%= experience.destination %>, <%= experience.country %></h4>
            
            <hr>
            
            <p><strong>Category:</strong> <%= experience.category %></p>
            <p><strong>Date of Experience:</strong> <%= experience.experienceDate %></p>
            <p><strong>Status:</strong> <%= experience.status %></p>
            <p><strong>Price:</strong> $<%= experience.price %></p>
            <p><strong>Rating:</strong> <%= experience.rating ? experience.rating + ' / 5' : 'No rating yet' %></p>
            <p><strong>Description:</strong></p>
            <p><%= experience.description %></p>
            
            <p class="text-muted mt-4"><em>Experience added by: <%= experience.username %></em></p>
            
            <a href="/experiences" class="btn btn-secondary">Back to All Experiences</a>
            
            <% if (user && (user.userId === experience.userId || user.role === 'admin')) { %>
                <a href="/experiences/<%= experience.experienceId %>/edit" class="btn btn-warning">Edit Experience</a>
            <% } %>
        </div>
    </div>
</div>

<%- include('./partials/footer') %>
<%# Member 4 - Jerome: Edit and delete action controls %>
<%- include('partials/header') %>

<article class="detail-layout">
    <div class="detail-media">
        <% if (experience.image) { %>
            <img src="/images/<%= experience.image %>" alt="<%= experience.title %>">
        <% } else { %>
            <div class="image-placeholder large-placeholder">No image uploaded</div>
        <% } %>
    </div>
    <div class="detail-content">
        <div class="card-meta">
            <span class="status status-<%= experience.status %>"><%= experience.status %></span>
            <span><%= experience.category %></span>
        </div>
        <h1><%= experience.title %></h1>
        <p class="lead"><%= experience.destination %>, <%= experience.country %></p>

        <dl class="detail-list">
            <div><dt>Date</dt><dd><%= new Date(experience.experienceDate).toLocaleDateString('en-SG') %></dd></div>
            <div><dt>Estimated price</dt><dd>$<%= Number(experience.price).toFixed(2) %></dd></div>
            <div><dt>Rating</dt><dd><%= experience.rating ? `${experience.rating}/5` : 'Not rated' %></dd></div>
            <div><dt>Created by</dt><dd><%= experience.username %></dd></div>
        </dl>

        <h2>Description</h2>
        <p class="description"><%= experience.description %></p>

        <div class="button-row">
            <a class="button button-secondary" href="/experiences">Back</a>
            <% if (user && (user.role === 'admin' || user.userId === experience.userId)) { %>
                <a class="button" href="/experiences/<%= experience.experienceId %>/edit">Edit</a>
                <form action="/experiences/<%= experience.experienceId %>/delete" method="POST" onsubmit="return confirm('Delete this experience?');">
                    <button class="button button-danger" type="submit">Delete</button>
                </form>
            <% } %>
        </div>
    </div>
</article>

<%- include('partials/footer') %>
