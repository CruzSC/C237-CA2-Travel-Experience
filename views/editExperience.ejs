<%# Member 4 - Jerome: Edit Experience view %>
<%- include('partials/header') %>

<section class="form-section">
    <div class="section-heading">
        <p class="eyebrow">Update plan</p>
        <h1>Edit experience</h1>
    </div>

    <form action="/experiences/<%= experience.experienceId %>/edit" method="POST" enctype="multipart/form-data" class="form-layout">
        <input type="hidden" name="currentImage" value="<%= experience.image || '' %>">
        <%- include('experienceFormFields', { experience }) %>
        <% if (experience.image) { %>
            <div class="current-image">
                <span>Current image</span>
                <img src="/images/<%= experience.image %>" alt="<%= experience.title %>">
            </div>
        <% } %>
        <div class="button-row">
            <button class="button" type="submit">Save changes</button>
            <a class="button button-secondary" href="/experiences/<%= experience.experienceId %>">Cancel</a>
        </div>
    </form>
</section>

<%- include('partials/footer') %>
