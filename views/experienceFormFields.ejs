<%# Shared by Member 2 - Ashton and Member 4 - Jerome %>
<div class="form-grid">
    <label>
        Title
        <input type="text" name="title" value="<%= experience ? experience.title : '' %>" required>
    </label>
    <label>
        City
        <input type="text" name="city" value="<%= experience ? experience.city : '' %>" required>
    </label>
    <label>
        Country
        <input type="text" name="country" value="<%= experience ? experience.country : '' %>" required>
    </label>
    <label>
        Category
        <select name="category" required>
            <option value="">Select category</option>
            <% ['Adventure', 'Culture', 'Food', 'Nature', 'Relaxation', 'Shopping'].forEach((option) => { %>
                <option value="<%= option %>" <%= experience && experience.category === option ? 'selected' : '' %>><%= option %></option>
            <% }) %>
        </select>
    </label>
    <label>
        Experience date
        <input type="date" name="experienceDate" value="<%= experience ? new Date(experience.experienceDate).toISOString().split('T')[0] : '' %>" required>
    </label>
    <label>
        Estimated price
        <input type="number" name="price" min="0" step="0.01" value="<%= experience ? experience.price : '' %>" required>
    </label>
    <label>
        Rating
        <select name="rating">
            <option value="">Not rated</option>
            <% [1, 2, 3, 4, 5].forEach((option) => { %>
                <option value="<%= option %>" <%= experience && Number(experience.rating) === option ? 'selected' : '' %>><%= option %></option>
            <% }) %>
        </select>
    </label>
    <label>
        Status
        <select name="status" required>
            <% ['planned', 'completed', 'cancelled'].forEach((option) => { %>
                <option value="<%= option %>" <%= (!experience && option === 'planned') || (experience && experience.status === option) ? 'selected' : '' %>><%= option %></option>
            <% }) %>
        </select>
    </label>
</div>

<label>
    Itinerary
    <textarea name="itinerary" rows="6" required><%= experience ? experience.itinerary : '' %></textarea>
</label>

<label>
    Experience image URL
    <input type="url" name="image" placeholder="https://example.com/photo.jpg" value="<%= experience && experience.image ? experience.image : '' %>">
</label>
